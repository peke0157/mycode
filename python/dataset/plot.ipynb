   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import librosa\n",
    "\n",
    "file_name = \"1-137-A-32.wav\"\n",
    "y, sr = librosa.load(file_name)\n",
    "\n",
    "L = len(y)\n",
    "t = np.arange(0,L) / sr\n",
    "\n",
    "plt.plot(t,y)\n",
    "plt.title('Audio waveform')\n",
    "plt.xlabel('time(s)')\n",
    "plt.ylabel('Amplitude')\n",
    "\n",
    "plt.show()\n"
   ]
  }
 ],
